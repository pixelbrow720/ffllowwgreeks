# ─── Databento ────────────────────────────────────────────────────────────────
# Two separate API keys are recommended — one per dataset / subscription tier:
#   * DATABENTO_API_KEY_OPRA   → OPRA.PILLAR (live + historical options chain)
#   * DATABENTO_API_KEY_GLOBEX → GLBX.MDP3   (live CME ES/NQ futures)
# DATABENTO_API_KEY (legacy single-key) is still honoured as a fallback when
# the dataset-specific keys above are empty. Leave it set to your old key
# during the transition; clear it once both new keys are populated.
DATABENTO_API_KEY=
DATABENTO_API_KEY_OPRA=your_opra_pillar_api_key_here
DATABENTO_API_KEY_GLOBEX=your_globex_mdp3_api_key_here

# ─── Database ─────────────────────────────────────────────────────────────────
# Inside Docker Compose, host is "db". For local (non-docker) dev use "localhost".
DATABASE_URL=postgresql+asyncpg://options:options@db:5432/options_db
POSTGRES_USER=options
POSTGRES_PASSWORD=options
POSTGRES_DB=options_db

# ─── Admin Auth ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# ADMIN_PASSWORD MUST be either a bcrypt hash starting with "$2" OR a
# plaintext password >= 12 characters. Boot refuses defaults / shorter
# values — see OPS.md "Initial deployment checklist" (SRE-10).
ADMIN_PASSWORD=changeme
# JWT_SECRET MUST be >= 32 random characters. Boot refuses defaults /
# shorter values (SRE-10).
JWT_SECRET=change_this_to_a_long_random_secret
# Default trimmed from 480 → 60 in Rev 8 SEC-2 to bound leaked-token
# blast radius. Server-side ``/admin/logout`` revocation closes the
# logout window completely; this knob only governs idle expiry.
JWT_EXPIRE_MINUTES=60

# ─── DB-at-rest Encryption ────────────────────────────────────────────────────
# Operator-managed secret used to derive the Fernet key that encrypts
# the Databento API key pool (databento_api_keys.api_key_encrypted).
# Decoupled from JWT_SECRET so admins can rotate the JWT signing key
# without invalidating every encrypted row in the DB. Empty falls back
# to JWT_SECRET (legacy behaviour); set this once and run the
# re-encryption job before rotating JWT_SECRET on existing deployments.
DB_ENCRYPTION_KEY=change_this_to_a_long_random_secret_distinct_from_jwt

# ─── Options Config ───────────────────────────────────────────────────────────
SUPPORTED_SYMBOLS=SPXW,NDXP
RISK_FREE_RATE=0.05
DATA_RETENTION_DAYS=7
COMPUTE_INTERVAL_SECONDS=60
HISTORICAL_BACKFILL_DAYS=7

# Hours of options_chain history scanned per pipeline tick to find the
# latest snapshot per contract. Tighter = less hypertable scan cost.
# Default 6h is plenty for live RTH; bump toward 48 if your feed has
# multi-hour gaps where contracts go un-quoted.
LOADER_SNAPSHOT_WINDOW_HOURS=6

# ─── Ingestion Behavior ───────────────────────────────────────────────────────
# Set to "true" to skip live Databento ingestion at startup (useful for dev/testing)
DISABLE_LIVE_INGESTION=false
# Set to "true" to skip historical backfill at startup
DISABLE_HISTORICAL_BACKFILL=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Allowed origins for /v1/* and /admin/*. Set this to your real consumer
# origin in production — never leave it as a wildcard ("*") on a public
# deployment.
ADMIN_CORS_ORIGINS=http://localhost:3000

# Set to "false" in production to disable the FastAPI /docs, /redoc and
# /openapi.json surfaces. The schema does not need to be browsable on
# public deployments and disabling these reduces the attack surface.
ENABLE_OPENAPI_DOCS=true

# Comma-separated list of trusted reverse-proxy IPs whose
# X-Forwarded-* headers uvicorn will honour. Set to the
# Cloudflare/Caddy/nginx hop in front of the API; leave at "127.0.0.1"
# when running directly on the host.
FORWARDED_ALLOW_IPS=127.0.0.1

# SRE-13: --proxy-headers is now opt-in. Set TRUST_PROXY_HEADERS=true
# only when a stripping reverse proxy (Cloudflare, ingress) is in
# front of the API and the FORWARDED_ALLOW_IPS list pins that hop —
# otherwise a remote client can spoof X-Forwarded-For and bypass
# per-IP rate limits / audit logging. Default: false (the API only
# trusts the socket peer).
TRUST_PROXY_HEADERS=false

# SRE-2: emergency hatch to skip the boot-time `alembic upgrade head`
# step. Useful when a deploy is failing on a migration and the
# operator needs to break the boot loop while diagnosing. Default
# unset (migrations run normally).
# SKIP_MIGRATIONS=1

# SRE-7: when true, the boot-time Postgres advisory-lock guard that
# refuses to start a second backend replica is bypassed. In-process
# state (deferred usage buffer, HIRO incremental cache, basis EMA,
# snapshot prime cache) is NOT consistent across replicas — see
# OPS.md "Single-instance assertion" before enabling.
ALLOW_MULTI_INSTANCE=false
