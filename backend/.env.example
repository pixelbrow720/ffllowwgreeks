# FlowGreeks environment template.
# Copy to .env and fill in real values. NEVER commit .env.

# ──────── Databento (single credential) ────────
DATABENTO_API_KEY=

# ──────── Postgres / TimescaleDB ────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=flowgreeks
POSTGRES_PASSWORD=flowgreeks_dev_only
POSTGRES_DB=flowgreeks
# Pool tuning (optional). Empty = pgx defaults. Tune per binary as needed:
# api ~ 10/2, ingest ~ 4/1, compute ~ 4/1.
POSTGRES_MAX_CONNS=
POSTGRES_MIN_CONNS=
POSTGRES_MAX_CONN_LIFETIME=
POSTGRES_MAX_CONN_IDLE_TIME=

# ──────── Redis ────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ──────── NATS ────────
NATS_URL=nats://localhost:4222

# ──────── API ────────
API_LISTEN_ADDR=:8080
API_CORS_ORIGINS=http://localhost:3000
# Comma-separated CIDR list of front-line proxies (LB / ingress). Only
# requests whose RemoteAddr matches one of these will have their
# X-Forwarded-For header honoured for source-IP attribution. Empty =
# trust nothing → XFF ignored, RemoteAddr used directly. Set to your
# LB / ingress subnets in production so audit logs + per-IP rate limits
# can't be spoofed by a hostile client.
API_TRUSTED_PROXIES=

# ──────── Logging ────────
LOG_LEVEL=info
LOG_FORMAT=json

# ──────── Environment ────────
APP_ENV=development

# ──────── API-key auth ────────
# FlowGreeks runs as an add-on inside flowjob.id. The parent site
# provisions opaque API keys against this binary; clients send them as
# `Authorization: Bearer <secret>` or `X-API-Key: <secret>`.
#
# When APIKEY_ENABLED=true the protected surface (/api/simulate,
# /api/alerts/*, /api/backtest/run) requires a valid key. false leaves
# the surface open — fine for local dev, refused at boot when
# APP_ENV=production.
APIKEY_ENABLED=false
